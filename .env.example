# Umami analytics website ID (cloud.umami.is → your site → Settings).
# Leave unset to disable analytics entirely (no script is injected).
PUBLIC_UMAMI_WEBSITE_ID=

# Resend API key (resend.com → API Keys). Server-only — never prefix with
# PUBLIC_, this must not reach the client bundle. Used by /api/contact to
# send contact-form messages as real email (Reply-To set to the sender).
RESEND_API_KEY=
