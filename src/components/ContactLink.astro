---
import Icon from './Icon.astro';

interface Props {
  href: string;
  icon: 'mail' | 'linkedin' | 'github';
  external?: boolean;
}

const { href, icon, external = false } = Astro.props;
---

<a
	href={href}
	target={external ? '_blank' : undefined}
	rel={external ? 'noopener noreferrer' : undefined}
	class="flex items-center gap-2 rounded border px-4 py-2 text-sm font-medium"
	style={{ borderColor: 'var(--border-default)', color: 'var(--text-body)' }}
>
	<Icon name={icon} />
	<slot />
</a>
