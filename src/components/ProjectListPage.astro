---
import ProjectCard from './ProjectCard.astro';
import { getAllProjects } from '../lib/projects';
import { useTranslations } from '../i18n/utils';
import { getTagColor } from '../lib/tagColor';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  prefix: string;
}

const { locale, prefix } = Astro.props;
const t = useTranslations(locale);
const projects = await getAllProjects(locale);
const slug = (id: string) => id.split('/').slice(1).join('/');

const allTags = [...new Set(projects.flatMap((p) => p.data.tags))].sort();
---

<h1 class="text-3xl font-bold" style={{ color: 'var(--text-heading)' }}>{t('projects.title')}</h1>

<p class="mt-3 text-sm" style={{ color: 'var(--text-muted)' }} id="tag-filters-hint">{t('projects.filterHint')}</p>
<div class="mt-2 flex flex-wrap gap-2" id="tag-filters">
	{allTags.map((tag) => {
		const color = getTagColor(tag);
		return (
			<button
				type="button"
				data-tag={tag}
				data-color={color}
				class="tag-filter-btn rounded px-3 py-1 text-sm font-medium transition"
				style={{ background: `${color}26`, color }}
			>
				{tag}
			</button>
		);
	})}
</div>

<div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2" id="project-grid">
	{projects.map((project) => (
		<ProjectCard
			href={`${prefix}/projects/${slug(project.id)}`}
			title={project.data.title}
			org={project.data.org}
			dateRange={project.data.dateRange}
			description={project.data.description}
			tags={project.data.tags}
		/>
	))}
</div>

<script>
	const filterButtons = document.querySelectorAll<HTMLButtonElement>('.tag-filter-btn');
	const cards = document.querySelectorAll<HTMLElement>('#project-grid [data-tags]');
	const selected = new Set<string>();

	function applyFilter() {
		cards.forEach((card) => {
			const cardTags = (card.dataset.tags ?? '').split(',');
			const visible = selected.size === 0 || cardTags.some((tag) => selected.has(tag));
			card.style.display = visible ? '' : 'none';
		});
	}

	filterButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const tag = button.dataset.tag ?? '';
			const color = button.dataset.color ?? '';
			const isSelected = selected.has(tag);

			if (isSelected) {
				selected.delete(tag);
				button.style.background = `${color}26`;
				button.style.color = color;
				button.setAttribute('aria-pressed', 'false');
			} else {
				selected.add(tag);
				button.style.background = color;
				button.style.color = '#fff';
				button.setAttribute('aria-pressed', 'true');
			}

			applyFilter();
		});
	});
</script>
