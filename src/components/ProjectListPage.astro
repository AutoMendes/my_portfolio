---
import ProjectCard from './ProjectCard.astro';
import { getAllProjects } from '../lib/projects';
import { useTranslations } from '../i18n/utils';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  prefix: string;
}

const { locale, prefix } = Astro.props;
const t = useTranslations(locale);
const projects = await getAllProjects(locale);
const slug = (id: string) => id.split('/').slice(1).join('/');

const allTags = [...new Set(projects.flatMap((p) => p.data.tags))].sort();
---

<h1 class="text-3xl font-bold" style={{ color: 'var(--text-heading)' }}>{t('projects.title')}</h1>

<p class="mt-3 text-sm" style={{ color: 'var(--text-muted)' }}>{t('projects.filterHint')}</p>
<div class="mt-2 flex flex-wrap gap-2" id="tag-filters">
	<button
		type="button"
		data-tag=""
		aria-pressed="true"
		class="tag-filter-btn rounded px-3 py-1 text-sm font-medium transition"
		style={{ background: 'var(--accent)', color: 'var(--accent-text)' }}
	>
		{t('projects.filterAll')}
	</button>
	{allTags.map((tag) => (
		<button
			type="button"
			data-tag={tag}
			aria-pressed="false"
			class="tag-filter-btn rounded px-3 py-1 text-sm font-medium transition"
			style={{ background: 'var(--bg-chrome)', color: 'var(--text-secondary)' }}
		>
			{tag}
		</button>
	))}
</div>

<div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2" id="project-grid">
	{projects.map((project) => (
		<ProjectCard
			href={`${prefix}/projects/${slug(project.id)}`}
			title={project.data.title}
			org={project.data.org}
			dateRange={project.data.dateRange}
			description={project.data.description}
			tags={project.data.tags}
		/>
	))}
</div>

<script>
	const filterButtons = document.querySelectorAll<HTMLButtonElement>('.tag-filter-btn');
	const allButton = document.querySelector<HTMLButtonElement>('.tag-filter-btn[data-tag=""]');
	const tagButtons = document.querySelectorAll<HTMLButtonElement>('.tag-filter-btn[data-tag]:not([data-tag=""])');
	const cards = document.querySelectorAll<HTMLElement>('#project-grid [data-tags]');
	const selected = new Set<string>();

	function paint(button: HTMLButtonElement, active: boolean) {
		button.setAttribute('aria-pressed', String(active));
		button.style.background = active ? 'var(--accent)' : 'var(--bg-chrome)';
		button.style.color = active ? 'var(--accent-text)' : 'var(--text-secondary)';
	}

	function render() {
		paint(allButton!, selected.size === 0);
		tagButtons.forEach((button) => paint(button, selected.has(button.dataset.tag ?? '')));

		cards.forEach((card) => {
			const cardTags = (card.dataset.tags ?? '').split(',');
			const visible = selected.size === 0 || cardTags.some((tag) => selected.has(tag));
			card.style.display = visible ? '' : 'none';
		});
	}

	allButton?.addEventListener('click', () => {
		selected.clear();
		render();
	});

	tagButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const tag = button.dataset.tag ?? '';
			if (selected.has(tag)) selected.delete(tag);
			else selected.add(tag);
			render();
		});
	});
</script>
