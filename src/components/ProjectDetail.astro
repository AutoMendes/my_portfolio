---
import { render } from 'astro:content';
import { getTagColor } from '../lib/tagColor';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<article>
	<h1 class="text-3xl font-bold" style={{ color: 'var(--text-heading)' }}>{project.data.title}</h1>
	<p class="mt-1 text-sm" style={{ color: 'var(--text-muted)' }}>{project.data.org} · {project.data.dateRange}</p>

	<ul class="mt-3 flex flex-wrap gap-2">
		{project.data.tags.map((tag) => {
			const color = getTagColor(tag);
			return (
				<li class="rounded px-2 py-0.5 text-xs font-medium" style={{ background: `${color}26`, color }}>
					{tag}
				</li>
			);
		})}
	</ul>

	<p class="mt-6 leading-relaxed" style={{ color: 'var(--text-body)' }}>{project.data.description}</p>

	{project.data.caseStudy && (
		<div class="prose mt-8">
			<Content />
		</div>
	)}
</article>
