---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactLink from '../../components/ContactLink.astro';

const status = Astro.url.searchParams.get('sent') ? 'sent' : Astro.url.searchParams.get('error') ? 'error' : null;
---

<BaseLayout title="Contacto — Tiago Lobo">
	<h1 class="text-3xl font-bold" style={{ color: 'var(--text-heading)' }}>Contacto</h1>

	<div class="mt-6 grid grid-cols-1 gap-10 md:grid-cols-[16rem_1fr]">
		<div class="flex flex-col gap-3">
			<ContactLink href="mailto:tiagolobo.eng@gmail.com" icon="mail">tiagolobo.eng@gmail.com</ContactLink>
			<ContactLink href="https://linkedin.com/in/tiagolobo10" icon="linkedin" external>LinkedIn</ContactLink>
			<ContactLink href="https://github.com/AutoMendes" icon="github" external>GitHub</ContactLink>
		</div>

		<div class="max-w-md">
			<form action="/api/contact" method="POST" class="space-y-4">
				<input type="hidden" name="redirect" value="/pt/contact" />
				<div>
					<label for="name" class="block text-sm font-medium" style={{ color: 'var(--text-body)' }}>Nome</label>
					<input
						type="text"
						id="name"
						name="name"
						required
						class="mt-1 w-full rounded border px-3 py-2"
						style={{ borderColor: 'var(--border-default)', background: 'var(--bg-page)', color: 'var(--text-body)' }}
					/>
				</div>
				<div>
					<label for="email" class="block text-sm font-medium" style={{ color: 'var(--text-body)' }}>Email</label>
					<input
						type="email"
						id="email"
						name="email"
						required
						class="mt-1 w-full rounded border px-3 py-2"
						style={{ borderColor: 'var(--border-default)', background: 'var(--bg-page)', color: 'var(--text-body)' }}
					/>
				</div>
				<div>
					<label for="subject" class="block text-sm font-medium" style={{ color: 'var(--text-body)' }}>Assunto</label>
					<input
						type="text"
						id="subject"
						name="_subject"
						required
						class="mt-1 w-full rounded border px-3 py-2"
						style={{ borderColor: 'var(--border-default)', background: 'var(--bg-page)', color: 'var(--text-body)' }}
					/>
				</div>
				<div>
					<label for="message" class="block text-sm font-medium" style={{ color: 'var(--text-body)' }}>Mensagem</label>
					<textarea
						id="message"
						name="message"
						rows="5"
						required
						class="mt-1 w-full rounded border px-3 py-2"
						style={{ borderColor: 'var(--border-default)', background: 'var(--bg-page)', color: 'var(--text-body)' }}
					></textarea>
				</div>
				<button
					type="submit"
					class="rounded px-4 py-2 font-medium"
					style={{ background: 'var(--accent)', color: 'var(--accent-text)' }}
				>
					Enviar mensagem
				</button>
			</form>
		</div>
	</div>

	{status && (
		<div
			id="contact-toast"
			class="fixed right-6 top-6 z-50 max-w-xs rounded border px-4 py-3 text-sm shadow-lg transition-opacity duration-500"
			style={
				status === 'sent'
					? { borderColor: 'var(--accent)', color: 'var(--accent)', background: 'var(--bg-chrome)' }
					: { borderColor: '#e07a5f', color: '#e07a5f', background: 'var(--bg-chrome)' }
			}
		>
			{status === 'sent'
				? 'Mensagem enviada — obrigado! Respondo em breve.'
				: 'Algo correu mal ao enviar a mensagem — tenta de novo, ou envia-me um email diretamente.'}
		</div>
	)}
</BaseLayout>

<script>
	const toast = document.getElementById('contact-toast');
	if (toast) {
		setTimeout(() => {
			toast.style.opacity = '0';
			setTimeout(() => toast.remove(), 500);
		}, 4000);

		const url = new URL(window.location.href);
		url.searchParams.delete('sent');
		url.searchParams.delete('error');
		window.history.replaceState({}, '', url);
	}
</script>
