---
import '../styles/global.css';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { ThemeToggle } from '../components/ThemeToggle';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import SocialIcons from '../components/SocialIcons.astro';
import { ArcadeModeController } from '../components/ArcadeModeController';
import { THEME_STORAGE_KEY } from '../lib/theme';
import { getAllProjects } from '../lib/projects';

interface Props {
  title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const prefix = lang === 'en' ? '' : `/${lang}`;

const allProjects = await getAllProjects(lang);
const arcadeProjects = allProjects.map((project) => ({
  slug: project.id.split('/').slice(1).join('/'),
  title: project.data.title,
  description: project.data.description,
  href: `${prefix}/projects/${project.id.split('/').slice(1).join('/')}`,
}));
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline define:vars={{ key: THEME_STORAGE_KEY }}>
			(function () {
				var stored = localStorage.getItem(key);
				var theme =
					stored === 'dark' || stored === 'light'
						? stored
						: window.matchMedia('(prefers-color-scheme: light)').matches
							? 'light'
							: 'dark';
				document.documentElement.setAttribute('data-theme', theme);
			})();
		</script>
		{import.meta.env.PUBLIC_UMAMI_WEBSITE_ID && (
			<script defer src="https://cloud.umami.is/script.js" data-website-id={import.meta.env.PUBLIC_UMAMI_WEBSITE_ID} />
		)}
	</head>
	<body class="flex min-h-screen flex-col">
		<header class="border-b" style={{ borderColor: 'var(--border-default)' }}>
			<nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4">
				<a href={`${prefix}/`} class="font-semibold" style={{ color: 'var(--text-heading)' }}>Tiago Lobo</a>

				<ul class="hidden gap-6 text-sm md:flex">
					<li><a href={`${prefix}/`}>{t('nav.home')}</a></li>
					<li><a href={`${prefix}/projects`}>{t('nav.projects')}</a></li>
					<li><a href={`${prefix}/about`}>{t('nav.about')}</a></li>
					<li><a href={`${prefix}/contact`}>{t('nav.contact')}</a></li>
				</ul>

				<div class="flex items-center gap-3">
					<LanguageSwitcher locale={lang} pathname={Astro.url.pathname} />
					<ThemeToggle client:load />

					<details class="relative md:hidden">
						<summary
							class="flex h-9 w-9 cursor-pointer items-center justify-center rounded border text-lg"
							style={{ borderColor: 'var(--border-default)', color: 'var(--text-body)' }}
							aria-label="Menu"
						>
							☰
						</summary>
						<ul
							class="absolute right-0 z-20 mt-2 flex w-40 flex-col gap-1 rounded border p-2 text-sm shadow-lg"
							style={{ borderColor: 'var(--border-default)', background: 'var(--bg-chrome)' }}
						>
							<li><a class="block rounded px-2 py-1.5" href={`${prefix}/`}>{t('nav.home')}</a></li>
							<li><a class="block rounded px-2 py-1.5" href={`${prefix}/projects`}>{t('nav.projects')}</a></li>
							<li><a class="block rounded px-2 py-1.5" href={`${prefix}/about`}>{t('nav.about')}</a></li>
							<li><a class="block rounded px-2 py-1.5" href={`${prefix}/contact`}>{t('nav.contact')}</a></li>
						</ul>
					</details>
				</div>
			</nav>
		</header>

		<main class="mx-auto w-full max-w-6xl flex-1 px-4 py-8">
			<slot />
		</main>

		<footer class="flex flex-col items-center justify-center gap-2 border-t border-gray-200 px-4 py-4 text-center text-sm text-gray-500 dark:border-gray-800 sm:flex-row sm:gap-4">
			<span>&copy; {new Date().getFullYear()} Tiago Lobo</span>
			<div class="flex items-center gap-4">
				<SocialIcons />
				<ArcadeModeController projects={arcadeProjects} client:load />
			</div>
		</footer>
	</body>
</html>
