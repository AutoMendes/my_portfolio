---
import '../styles/global.css';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { ThemeToggle } from '../components/ThemeToggle';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import { ArcadeModeController } from '../components/ArcadeModeController';
import { THEME_STORAGE_KEY } from '../lib/theme';
import { getAllProjects } from '../lib/projects';

interface Props {
  title: string;
}

const { title } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const prefix = lang === 'en' ? '' : `/${lang}`;

const allProjects = await getAllProjects(lang);
const arcadeProjects = allProjects.map((project) => ({
  slug: project.id.split('/').slice(1).join('/'),
  title: project.data.title,
  description: project.data.description,
  href: `${prefix}/projects/${project.id.split('/').slice(1).join('/')}`,
}));
---

<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline define:vars={{ key: THEME_STORAGE_KEY }}>
			(function () {
				var stored = localStorage.getItem(key);
				var theme =
					stored === 'dark' || stored === 'light'
						? stored
						: window.matchMedia('(prefers-color-scheme: light)').matches
							? 'light'
							: 'dark';
				document.documentElement.setAttribute('data-theme', theme);
			})();
		</script>
	</head>
	<body class="flex min-h-screen flex-col">
		<header class="border-b border-gray-200 dark:border-gray-800">
			<nav class="mx-auto flex max-w-4xl items-center justify-between px-4 py-4">
				<a href={`${prefix}/`} class="font-semibold">Tiago Lobo</a>
				<ul class="flex gap-6 text-sm">
					<li><a href={`${prefix}/`}>{t('nav.home')}</a></li>
					<li><a href={`${prefix}/projects`}>{t('nav.projects')}</a></li>
					<li><a href={`${prefix}/about`}>{t('nav.about')}</a></li>
					<li><a href={`${prefix}/contact`}>{t('nav.contact')}</a></li>
				</ul>
				<div class="flex items-center gap-4">
					<LanguageSwitcher locale={lang} pathname={Astro.url.pathname} />
					<ThemeToggle client:load />
				</div>
			</nav>
		</header>

		<main class="mx-auto w-full max-w-4xl flex-1 px-4 py-8">
			<slot />
		</main>

		<footer class="flex items-center justify-center gap-3 border-t border-gray-200 px-4 py-6 text-center text-sm text-gray-500 dark:border-gray-800">
			<span>&copy; {new Date().getFullYear()} Tiago Lobo</span>
			<ArcadeModeController projects={arcadeProjects} client:load />
		</footer>
	</body>
</html>
